<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🧠 MR.MIND</title>
  <style>
    body {
      font-family: system-ui, sans-serif;
      background: linear-gradient(135deg, #0f172a, #1e2937);
      color: #e2e8f0;
      margin: 0;
      padding: 20px;
    }
    .container { max-width: 1000px; margin: auto; }
    h1 { text-align: center; color: #60a5fa; font-size: 2.8rem; }
    .subtitle { text-align: center; color: #94a3b8; margin-bottom: 30px; }
    .ai-badge {
      display: block;
      text-align: center;
      color: #34d399;
      font-size: 0.8rem;
      margin-bottom: 20px;
      letter-spacing: 0.05em;
    }

    .lang-select {
      padding: 14px;
      font-size: 16px;
      background: #334155;
      color: white;
      border-radius: 12px;
      width: 100%;
      margin: 15px 0;
      border: none;
      box-sizing: border-box;
    }

    textarea, input {
      width: 100%;
      padding: 18px;
      background: #1e2937;
      border: none;
      border-radius: 16px;
      color: white;
      font-size: 16px;
      transition: all 0.3s ease;
      box-sizing: border-box;
      font-family: inherit;
    }
    textarea:focus, input:focus {
      outline: none;
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.3);
      transform: scale(1.01);
    }

    /* Original button & tab styles */
    button, .tab {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
      padding: 14px 24px;
      border-radius: 9999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-weight: 600;
      white-space: nowrap;
      cursor: pointer;
      font-size: 15px;
      margin: 6px 6px 6px 0;
    }

    button {
      color: white;
      border: none;
      background: #3b82f6;
    }
    button:hover:not(:disabled) {
      transform: translateY(-6px) scale(1.05);
      box-shadow: 0 20px 25px -5px rgb(59 130 246 / 0.6);
    }
    button:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }

    .tab { background: #1e2937; }
    .tab:hover { transform: translateY(-6px) scale(1.05); }
    .tab.active { background: #3b82f6; transform: translateY(-2px); }

    .edit-btn { background: #10b981; }
    .translate-btn { background: #8b5cf6; }
    .delete-btn { background: #ef4444; }
    .edit-btn:hover { box-shadow: 0 20px 25px -5px rgb(16 185 129 / 0.7); }
    .translate-btn:hover { box-shadow: 0 20px 25px -5px rgb(139 92 246 / 0.7); }
    .delete-btn:hover { box-shadow: 0 20px 25px -5px rgb(239 68 68 / 0.7); }

    .memory {
      background: #1e2937;
      padding: 20px;
      margin: 15px 0;
      border-radius: 16px;
      transition: all 0.3s ease;
    }
    .memory:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.2); }

    button img, .tab img { width: 26px; height: 26px; filter: brightness(1.1); flex-shrink: 0; }

    .translation-box {
      margin-top: 12px;
      padding: 14px;
      background: #111827;
      border-left: 3px solid #8b5cf6;
      border-radius: 8px;
      font-style: italic;
    }

    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .status-msg { color: #94a3b8; font-size: 0.9rem; margin-top: 8px; }
    .error-msg { color: #f87171; font-size: 0.9rem; margin-top: 8px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>🧠 MR.MIND</h1>
    <p class="subtitle">Your Personal Intelligent Memory Companion</p>
    <p class="ai-badge">✨ Powered by real AI reasoning over your memories</p>

    <label><strong>🌐 Target Language:</strong></label>
    <select id="langSelect" class="lang-select">
      <option value="ta">தமிழ் - Tamil</option>
      <option value="hi">हिन्दी - Hindi</option>
      <option value="te">తెలుగు - Telugu</option>
      <option value="en">English</option>
    </select>

    <div style="display:flex; gap:12px; margin:30px 0; flex-wrap:wrap;">
      <div onclick="switchTab(0)" class="tab active" id="tabBtn0">📝 New Memory</div>
      <div onclick="switchTab(1)" class="tab" id="tabBtn1">🔎 Ask AI</div>
      <div onclick="switchTab(2)" class="tab" id="tabBtn2">🔖 All Memories</div>
    </div>

    <div id="tab0">
      <textarea id="journal" rows="8" placeholder="What happened today, Sir?"></textarea><br>
      <button onclick="saveMemory()">💾 Save / Update Memory</button>
      <button onclick="startVoiceInput()">🎙️ Voice Input</button>
      <div id="saveStatus" class="status-msg"></div>
    </div>

    <div id="tab1" style="display:none">
      <input id="query" placeholder="Ask anything about your memories" onkeypress="if(event.key==='Enter') askAI()">
      <button id="askBtn" onclick="askAI()">🔎 Ask AI</button>
      <div id="response" style="margin-top:25px; line-height:1.7"></div>
    </div>

    <div id="tab2" style="display:none">
      <button onclick="showAllMemories()">🔄 Refresh</button>
      <div id="memoriesList"></div>
    </div>
  </div>

  <script>
    let memories = [];
    let editingIndex = -1;
    let storageReady = false;

    // Subtle hover "click" using the Web Audio API (no external file needed)
    let audioCtx = null;
    function playHoverSound() {
      try {
        audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.value = 700;
        gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.12);
        osc.connect(gain).connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.12);
      } catch (e) { /* audio not available, ignore */ }
    }

    function attachHoverSounds() {
      document.querySelectorAll('button, .tab').forEach(el => {
        el.removeEventListener('mouseenter', playHoverSound);
        el.addEventListener('mouseenter', playHoverSound);
      });
    }

    // ---------- Storage (persistent, replaces localStorage) ----------
    async function loadMemories() {
      try {
        const result = await window.storage.get('memories');
        memories = result ? JSON.parse(result.value) : [];
      } catch (e) {
        memories = [];
      }
      storageReady = true;
    }

    async function persistMemories() {
      try {
        const result = await window.storage.set('memories', JSON.stringify(memories));
        if (!result) console.error('Storage set returned null');
      } catch (e) {
        console.error('Storage error:', e);
      }
    }

    // ---------- Speech ----------
    function speak(text) {
      if ('speechSynthesis' in window) {
        const u = new SpeechSynthesisUtterance(text);
        const lang = document.getElementById('langSelect').value;
        u.lang = lang === 'ta' ? 'ta-IN' : lang === 'hi' ? 'hi-IN' : lang === 'te' ? 'te-IN' : 'en-US';
        speechSynthesis.speak(u);
      }
    }

    window.onload = async () => {
      await loadMemories();
      setTimeout(() => speak("Welcome to your Mind Palace, Sir."), 800);
      attachHoverSounds();
    };

    // ---------- Real AI call helper ----------
    async function callClaude(systemPrompt, userMessage) {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          system: systemPrompt,
          messages: [{ role: "user", content: userMessage }]
        })
      });
      if (!response.ok) {
        throw new Error("API request failed: " + response.status);
      }
      const data = await response.json();
      return data.content.map(b => b.text || "").join("\n").trim();
    }

    // ---------- Save memory ----------
    async function saveMemory() {
      const text = document.getElementById('journal').value.trim();
      const statusEl = document.getElementById('saveStatus');
      if (!text) { statusEl.textContent = "Write something first."; statusEl.className = 'error-msg'; return; }

      if (editingIndex >= 0) {
        memories[editingIndex].content = text;
        editingIndex = -1;
        statusEl.textContent = "✅ Memory updated!";
      } else {
        memories.unshift({
          id: Date.now(),
          date: new Date().toISOString().split('T')[0],
          content: text,
          timestamp: new Date().toISOString()
        });
        statusEl.textContent = "✅ Memory saved!";
      }
      statusEl.className = 'status-msg';
      await persistMemories();
      speak("Done, Sir.");
      document.getElementById('journal').value = '';
      if (document.getElementById('tab2').style.display === 'block') showAllMemories();
    }

    // ---------- Real AI-powered Q&A over memories ----------
    async function askAI() {
      const query = document.getElementById('query').value.trim();
      if (!query) return;

      const responseDiv = document.getElementById('response');
      const askBtn = document.getElementById('askBtn');
      askBtn.disabled = true;
      askBtn.innerHTML = '<span class="spinner"></span> Thinking...';
      responseDiv.innerHTML = '<p class="status-msg">Reasoning over your memories...</p>';

      try {
        const memoryContext = memories.length
          ? memories.map(m => `[${m.date}] ${m.content}`).join('\n---\n')
          : "(No memories have been recorded yet.)";

        const targetLang = document.getElementById('langSelect').value;
        const langName = { ta: 'Tamil', hi: 'Hindi', te: 'Telugu', en: 'English' }[targetLang];

        const systemPrompt = `You are Mr. Mind, a warm, thoughtful personal memory assistant. ` +
          `You are given a list of the user's personal journal entries (memories), each dated. ` +
          `Answer the user's question using ONLY information that can reasonably be inferred from these memories. ` +
          `If the memories don't contain relevant information, say so honestly rather than making things up. ` +
          `Be conversational, concise, and refer to specific dates when helpful. ` +
          `Respond in ${langName}.\n\nMEMORIES:\n${memoryContext}`;

        const answer = await callClaude(systemPrompt, query);
        responseDiv.innerHTML = `<div class="memory"><strong>🧠 Mr. Mind:</strong><br><br>${escapeHtml(answer).replace(/\n/g, '<br>')}</div>`;
        speak("Here is what I found.");
      } catch (e) {
        responseDiv.innerHTML = `<p class="error-msg">Something went wrong reaching the AI. Please try again.</p>`;
      } finally {
        askBtn.disabled = false;
        askBtn.innerHTML = '🔎 Ask AI';
      }
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ---------- Render all memories ----------
    function showAllMemories() {
      const container = document.getElementById('memoriesList');
      container.innerHTML = '';
      if (memories.length === 0) {
        container.innerHTML = "<p>No memories yet.</p>";
        return;
      }
      memories.forEach((m, i) => {
        const div = document.createElement('div');
        div.className = 'memory';
        div.innerHTML = `
          <strong>${m.date}</strong><br>
          ${escapeHtml(m.content)}
          <div style="margin-top:12px">
            <button onclick="editMemory(${i})" class="edit-btn">✏️ Edit</button>
            <button onclick="translateMemory(${i})" class="translate-btn" id="translateBtn${i}">🌐 Translate</button>
            <button onclick="deleteMemory(${i})" class="delete-btn">🗑️ Delete</button>
          </div>
          <div id="translationSlot${i}"></div>
        `;
        container.appendChild(div);
      });
      setTimeout(attachHoverSounds, 50);
    }

    function editMemory(i) {
      document.getElementById('journal').value = memories[i].content;
      editingIndex = i;
      switchTab(0);
    }

    // ---------- Real AI-powered translation (in-place, no external redirect) ----------
    async function translateMemory(i) {
      const btn = document.getElementById('translateBtn' + i);
      const slot = document.getElementById('translationSlot' + i);
      const target = document.getElementById('langSelect').value;
      const langName = { ta: 'Tamil', hi: 'Hindi', te: 'Telugu', en: 'English' }[target];

      btn.disabled = true;
      const originalLabel = btn.innerHTML;
      btn.innerHTML = '<span class="spinner"></span> Translating...';
      slot.innerHTML = '';

      try {
        const systemPrompt = `You are a precise translator. Translate the user's text into ${langName}. ` +
          `Respond with ONLY the translated text, no explanations, no quotes.`;
        const translated = await callClaude(systemPrompt, memories[i].content);
        slot.innerHTML = `<div class="translation-box">${escapeHtml(translated)}</div>`;
      } catch (e) {
        slot.innerHTML = `<p class="error-msg">Translation failed. Please try again.</p>`;
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalLabel;
      }
    }

    async function deleteMemory(i) {
      if (confirm("Delete this memory?")) {
        memories.splice(i, 1);
        await persistMemories();
        showAllMemories();
      }
    }

    function startVoiceInput() {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) return alert("Voice not supported. Use Chrome.");
      const r = new SpeechRecognition();
      const lang = document.getElementById('langSelect').value;
      r.lang = lang === 'ta' ? 'ta-IN' : lang === 'hi' ? 'hi-IN' : lang === 'te' ? 'te-IN' : 'en-US';
      r.onresult = e => document.getElementById('journal').value = e.results[0][0].transcript;
      r.start();
    }

    function switchTab(n) {
      document.getElementById('tab0').style.display = n===0 ? 'block' : 'none';
      document.getElementById('tab1').style.display = n===1 ? 'block' : 'none';
      document.getElementById('tab2').style.display = n===2 ? 'block' : 'none';
      [0,1,2].forEach(i => document.getElementById('tabBtn'+i).classList.toggle('active', i===n));
      if (n===2) showAllMemories();
    }
  </script>
</body>
</html>
